# Variáveis de Ambiente
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/filmpro_db"
JWT_SECRET="sua_chave_secreta_aqui_troque_em_producao"
JWT_EXPIRES_IN="7d"
PORT=3001
NODE_ENV=development

# URL do frontend (usada nos links do e-mail)
APP_URL=http://localhost:3000

# Configuração de E-mail SMTP
# Exemplos de provedores:
#   Gmail:   SMTP_HOST=smtp.gmail.com  | SMTP_PORT=587  | SMTP_SECURE=false
#            (use uma "Senha de app" em Conta Google > Segurança > Verificação em duas etapas)
#   Outlook: SMTP_HOST=smtp.office365.com | SMTP_PORT=587 | SMTP_SECURE=false
#   Mailtrap (testes): SMTP_HOST=sandbox.smtp.mailtrap.io | SMTP_PORT=2525 | SMTP_SECURE=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_de_app
SMTP_FROM_NAME=FilmPro Manager
