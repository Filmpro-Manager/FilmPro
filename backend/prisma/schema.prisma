// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// COMPANY
// ─────────────────────────────────────────
model Company {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")

  stores    Store[]
  users     User[]

  @@map("companies")
}

// ─────────────────────────────────────────
// STORE
// ─────────────────────────────────────────
model Store {
  id                 String   @id @default(uuid())
  companyId          String   @map("company_id")
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name               String
  logoUrl            String?  @map("logo_url")
  razaoSocial        String   @map("razao_social")
  nomeFantasia       String   @map("nome_fantasia")
  cnpj               String   @unique
  phone              String
  email              String

  addressStreet      String   @map("address_street")
  addressNumber      String   @map("address_number")
  addressComplement  String?  @map("address_complement")
  addressDistrict    String   @map("address_district")
  addressZipcode     String   @map("address_zipcode")
  addressCity        String   @map("address_city")
  addressState       String   @map("address_state")

  setupCompleted     Boolean  @default(false) @map("setup_completed")
  status             String   @default("active")
  createdAt          DateTime @default(now()) @map("created_at")

  users              User[]
  clients            Client[]
  vehicles           Vehicle[]
  inventoryItems     InventoryItem[]
  inventoryMovements InventoryMovement[]

  @@map("stores")
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────
model User {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  storeId      String?  @map("store_id")
  store        Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)

  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  phone        String

  // Roles: owner | manager | employee
  role         String   @default("employee")
  status       String   @default("active")
  createdAt    DateTime @default(now()) @map("created_at")

  inventoryMovements InventoryMovement[]

  @@map("users")
}

// ─────────────────────────────────────────
// CLIENT
// ─────────────────────────────────────────
model Client {
  id        String   @id @default(uuid())
  storeId   String   @map("store_id")
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name      String
  phone     String?
  email     String?
  document  String?  // CPF ou CNPJ
  notes     String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  vehicles  Vehicle[]

  @@map("clients")
}

// ─────────────────────────────────────────
// VEHICLE
// ─────────────────────────────────────────
model Vehicle {
  id       String  @id @default(uuid())
  clientId String  @map("client_id")
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  storeId  String  @map("store_id")
  store    Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  brand    String
  model    String
  year     Int?
  plate    String?
  color    String?
  notes    String?

  createdAt DateTime @default(now()) @map("created_at")

  @@map("vehicles")
}

// ─────────────────────────────────────────
// MASTER USER (dono do SaaS)
// ─────────────────────────────────────────
model MasterUser {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("master_users")
}

// ─────────────────────────────────────────
// INVENTORY
// ─────────────────────────────────────────
model InventoryItem {
  id          String   @id @default(uuid())
  storeId     String   @map("store_id")
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name        String
  brand       String
  type        String   // automotive | architecture | security | decorative | solar
  unit        String   @default("m")
  quantity    Float    @default(0)
  minQuantity Float    @default(0)   @map("min_quantity")
  costPrice   Float    @default(0)   @map("cost_price")
  pricePerUnit Float   @default(0)   @map("price_per_unit")
  transparency Int     @default(0)
  sku         String?

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  movements   InventoryMovement[]

  @@map("inventory_items")
}

model InventoryMovement {
  id              String        @id @default(uuid())
  storeId         String        @map("store_id")
  store           Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)

  inventoryItemId String        @map("inventory_item_id")
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  userId          String        @map("user_id")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // entrada | saida | ajuste
  type            String
  quantity        Float
  reason          String?

  createdAt       DateTime @default(now()) @map("created_at")

  @@map("inventory_movements")
}

