// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// COMPANY
// ─────────────────────────────────────────
model Company {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")

  stores       Store[]
  users        User[]
  subscription Subscription?

  @@map("companies")
}

// ─────────────────────────────────────────
// STORE
// ─────────────────────────────────────────
model Store {
  id                 String   @id @default(uuid())
  companyId          String   @map("company_id")
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name               String
  logoUrl            String?  @map("logo_url")
  razaoSocial        String   @map("razao_social")
  nomeFantasia       String   @map("nome_fantasia")
  cnpj               String   @unique
  phone              String
  email              String

  addressStreet      String   @map("address_street")
  addressNumber      String   @map("address_number")
  addressComplement  String?  @map("address_complement")
  addressDistrict    String   @map("address_district")
  addressZipcode     String   @map("address_zipcode")
  addressCity        String   @map("address_city")
  addressState       String   @map("address_state")

  setupCompleted     Boolean  @default(false) @map("setup_completed")
  status             String   @default("active")
  createdAt          DateTime @default(now()) @map("created_at")

  users              User[]
  clients            Client[]
  vehicles           Vehicle[]
  inventoryItems     InventoryItem[]
  inventoryMovements InventoryMovement[]
  serviceCatalog     ServiceCatalog[]
  quotes             Quote[]
  serviceOrders      ServiceOrder[]
  appointments       Appointment[]
  transactions       Transaction[]
  goals              Goal[]
  clientRatings      ClientRating[]

  @@map("stores")
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────
model User {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  storeId      String?  @map("store_id")
  store        Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)

  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  phone        String
  avatarUrl    String?  @map("avatar_url")

  // Roles: owner | manager | employee
  role         String   @default("employee")
  status       String   @default("active")
  createdAt    DateTime @default(now()) @map("created_at")

  passwordResetToken  String?   @map("password_reset_token")
  passwordResetExpiry DateTime? @map("password_reset_expiry")

  inventoryMovements InventoryMovement[]
  inventoryItemsCreated InventoryItem[] @relation("InventoryCreatedBy")
  quotesCreated Quote[] @relation("QuoteCreatedBy")
  serviceOrdersCreated ServiceOrder[] @relation("ServiceOrderCreatedBy")
  appointmentsCreated  Appointment[]  @relation("AppointmentCreatedBy")

  @@map("users")
}

// ─────────────────────────────────────────
// CLIENT
// ─────────────────────────────────────────
model Client {
  id        String   @id @default(uuid())
  storeId   String   @map("store_id")
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name      String
  phone     String?
  email     String?
  document  String?  // CPF ou CNPJ
  notes     String?

  // Endereço
  addressZipcode    String?  @map("address_zipcode")
  addressStreet     String?  @map("address_street")
  addressNumber     String?  @map("address_number")
  addressComplement String?  @map("address_complement")
  addressDistrict   String?  @map("address_district")
  addressCity       String?  @map("address_city")
  addressState      String?  @map("address_state")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  vehicles  Vehicle[]
  quotes    Quote[]

  @@map("clients")
}

// ─────────────────────────────────────────
// VEHICLE
// ─────────────────────────────────────────
model Vehicle {
  id       String  @id @default(uuid())
  clientId String  @map("client_id")
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  storeId  String  @map("store_id")
  store    Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  brand    String
  model    String
  year     Int?
  plate    String?
  color    String?
  notes    String?

  createdAt DateTime @default(now()) @map("created_at")

  @@map("vehicles")
}

// ─────────────────────────────────────────
// MASTER USER (dono do SaaS)
// ─────────────────────────────────────────
model MasterUser {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("master_users")
}

// ─────────────────────────────────────────
// INVENTORY
// ─────────────────────────────────────────
model InventoryItem {
  id          String   @id @default(uuid())
  storeId     String   @map("store_id")
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name        String
  brand       String
  type        String   // automotive | architecture | security | decorative | solar
  unit        String   @default("m")
  quantity    Float    @default(0)
  minQuantity Float    @default(0)   @map("min_quantity")
  costPrice   Float    @default(0)   @map("cost_price")
  pricePerUnit Float   @default(0)   @map("price_per_unit")
  transparency Int     @default(0)
  color       String?
  sku         String?
  rollWidth   Float?   @map("roll_width")

  createdById String?  @map("created_by_id")
  createdBy   User?    @relation("InventoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  movements   InventoryMovement[]

  @@map("inventory_items")
}

model InventoryMovement {
  id              String        @id @default(uuid())
  storeId         String        @map("store_id")
  store           Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)

  inventoryItemId String        @map("inventory_item_id")
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  userId          String        @map("user_id")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // entrada | saida | ajuste
  type            String
  quantity        Float
  reason          String?

  createdAt       DateTime @default(now()) @map("created_at")

  @@map("inventory_movements")
}

// ─────────────────────────────────────────
// SERVICE CATALOG
// ─────────────────────────────────────────
model ServiceCatalog {
  id               String   @id @default(uuid())
  storeId          String   @map("store_id")
  store            Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name             String
  description      String?
  category         String   // automotive | architecture
  price            Float
  estimatedMinutes Int?     @map("estimated_minutes")
  isActive         Boolean  @default(true) @map("is_active")

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt      @map("updated_at")

  @@map("service_catalog")
}

// ─────────────────────────────────────────
// QUOTES (Orçamentos)
// ─────────────────────────────────────────
model Quote {
  id        String @id @default(uuid())
  storeId   String @map("store_id")
  store     Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  number    String // ORC-2026-001

  // Status: draft | sent | approved | converted | expired | rejected
  status    String @default("draft")

  // Cliente (desnormalizado p/ histórico)
  clientId           String? @map("client_id")
  client             Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientName         String  @map("client_name")
  clientPhone        String? @map("client_phone")
  clientEmail        String? @map("client_email")
  clientDocument     String? @map("client_document")
  clientDocumentType String? @map("client_document_type")

  // Categoria e sujeito (JSON – veículo, edificação, etc.)
  category String? // automotive | architecture
  subject  Json?   // QuoteSubject

  // Vendedor
  sellerId   String? @map("seller_id")
  sellerName String? @map("seller_name")

  // Criado por
  createdById   String? @map("created_by_id")
  createdBy     User?   @relation("QuoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdByName String? @map("created_by_name")

  // Totais
  subtotal     Float  @default(0)
  discount     Float  @default(0)
  discountType String? @map("discount_type") // value | percent
  taxes        Float?
  totalValue   Float  @default(0) @map("total_value")

  // Pagamento
  acceptedPaymentMethods String[] @map("accepted_payment_methods")
  payment                Json?    // QuotePayment

  // Notas
  notes         String?
  internalNotes String? @map("internal_notes")

  // Datas
  issueDate  DateTime  @default(now()) @map("issue_date")
  validUntil DateTime? @map("valid_until")

  // Conversão para OS
  convertedAt              DateTime? @map("converted_at")
  convertedToAppointmentId String?   @map("converted_to_appointment_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  items QuoteItem[]

  @@map("quotes")
}

model QuoteItem {
  id      String @id @default(uuid())
  quoteId String @map("quote_id")
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  type         String // service | product | other
  name         String
  description  String?
  quantity     Float
  unit         String @default("un")
  unitPrice    Float  @map("unit_price")
  discount     Float  @default(0)
  discountType String @default("value") @map("discount_type")
  total        Float

  productId String? @map("product_id")
  serviceId String? @map("service_id")
  vehicleId String? @map("vehicle_id")

  @@map("quote_items")
}

// ─────────────────────────────────────────
// SERVICE ORDERS (Ordens de Serviço)
// ─────────────────────────────────────────
model ServiceOrder {
  id      String @id @default(uuid())
  storeId String @map("store_id")
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  number  String // OS-2026-001

  // Origem do orçamento
  quoteId String? @unique @map("quote_id")

  // Cliente (desnormalizado)
  clientId   String? @map("client_id")
  clientName String  @map("client_name")

  // Objeto do serviço
  vehicle     String?
  subject     Json?

  // Serviço principal
  serviceType String  @default("Serviço") @map("service_type")

  // Técnico
  employeeId   String? @map("employee_id")
  employeeName String? @map("employee_name")

  // Quando
  date      String
  endDate   String? @map("end_date")
  startTime String? @map("start_time")
  endTime   String? @map("end_time")

  // Status: draft | scheduled | in_progress | completed | cancelled
  status String @default("scheduled")

  // Valor
  value Float @default(0)

  // Itens (JSON – cópia dos itens do orçamento)
  items Json?

  // Notas
  notes         String?
  internalNotes String? @map("internal_notes")

  // Origem do agendamento
  sourceAppointmentId String? @map("source_appointment_id")

  // Criado por
  createdById   String? @map("created_by_id")
  createdBy     User?   @relation("ServiceOrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdByName String? @map("created_by_name")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("service_orders")
}

// ─────────────────────────────────────────
// TRANSACTIONS (Financeiro)
// ─────────────────────────────────────────
model Transaction {
  id          String  @id @default(uuid())
  storeId     String  @map("store_id")
  store       Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  // income | expense
  type        String
  description String
  amount      Float
  date        String    // data de competência (YYYY-MM-DD)
  dueDate     String?   @map("due_date")
  paidDate    String?   @map("paid_date")
  isPaid      Boolean   @default(true) @map("is_paid")
  paidAmount  Float?    @map("paid_amount")
  category    String
  costCenter  String?   @map("cost_center")
  paymentMethod String? @map("payment_method")

  isRecurring   Boolean @default(false) @map("is_recurring")
  recurrenceDay Int?    @map("recurrence_day")
  installments  Int?
  installmentNum Int?   @map("installment_num")
  installmentRef String? @map("installment_ref")

  clientId      String? @map("client_id")
  clientName    String? @map("client_name")
  appointmentId String? @map("appointment_id")
  invoiceId     String? @map("invoice_id")

  createdById   String? @map("created_by_id")
  createdByName String? @map("created_by_name")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("transactions")
}

// ─────────────────────────────────────────
// GOALS (Metas)
// ─────────────────────────────────────────
model Goal {
  id           String  @id @default(uuid())
  storeId      String  @map("store_id")
  store        Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  employeeId   String? @map("employee_id")
  employeeName String? @map("employee_name")

  // revenue | services | new_clients | ticket_average | conversion_rate
  type         String
  period       String  // YYYY-MM
  target       Float
  achieved     Float   @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("goals")
}

// ─────────────────────────────────────────
// APPOINTMENTS (Agenda)
// ─────────────────────────────────────────
model Appointment {
  id      String @id @default(uuid())
  storeId String @map("store_id")
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  number  String // AGD-2026-001

  // Status: scheduled | in_progress | completed | cancelled
  status  String @default("scheduled")

  // Cliente
  clientId   String? @map("client_id")
  clientName String  @map("client_name")

  // Veículo / Sujeito
  vehicle String?
  subject Json?

  // Serviço
  serviceType String @default("Serviço") @map("service_type")

  // Técnico
  employeeId   String? @map("employee_id")
  employeeName String? @map("employee_name")

  // Quando
  date      String  // YYYY-MM-DD
  endDate   String? @map("end_date")
  startTime String? @map("start_time")
  endTime   String? @map("end_time")

  // Valor estimado
  value Float @default(0)

  // Origem: orçamento (opcional)
  quoteId String? @map("quote_id")

  // Materiais utilizados (JSON – registrado ao concluir)
  materialsUsed Json? @map("materials_used")

  // Notas
  notes String?

  // Criado por
  createdById   String? @map("created_by_id")
  createdBy     User?   @relation("AppointmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdByName String? @map("created_by_name")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("appointments")
}

// ─────────────────────────────────────────
// CLIENT RATINGS (Avaliações / NPS)
// ─────────────────────────────────────────
model ClientRating {
  id            String  @id @default(uuid())
  storeId       String  @map("store_id")
  store         Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  appointmentId String? @map("appointment_id")
  clientId      String? @map("client_id")
  clientName    String? @map("client_name")

  score         Int     // 0-10 (NPS)
  comment       String?

  createdAt DateTime @default(now()) @map("created_at")

  @@map("client_ratings")
}

// ─────────────────────────────────────────
// SUBSCRIPTION (Assinatura)
// ─────────────────────────────────────────
model Subscription {
  id            String   @id @default(uuid())
  companyId     String   @unique @map("company_id")
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  status        String   @default("active")
  pricePerStore Int      @default(7990) @map("price_per_store")
  dueDate       DateTime @map("due_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  charges PixCharge[]

  @@map("subscriptions")
}

// ─────────────────────────────────────────
// PIX CHARGE (Cobrança PIX)
// ─────────────────────────────────────────
model PixCharge {
  id             String   @id @default(uuid())
  subscriptionId String   @map("subscription_id")
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  correlationId  String   @unique @map("correlation_id")
  externalId     String?  @map("external_id")
  amount         Int
  storeCount     Int      @map("store_count")
  referenceMonth String   @map("reference_month")
  status         String   @default("pending")
  brCode         String?  @map("br_code")
  qrCodeImage    String?  @map("qr_code_image")
  expiresAt      DateTime @map("expires_at")
  paidAt         DateTime? @map("paid_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("pix_charges")
}

